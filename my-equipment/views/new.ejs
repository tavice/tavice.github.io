     <!-- ============ HEADER ============ -->
     <%- include ('./partials/head.ejs') %>

     <!-- ============ HEADER============ -->
     <%- include ('./partials/header.ejs') %>

     <div class="container">
        <h1 class="text-center mb-5 main-title">Add New Equipment</h1>
        <form action="/equipment" method="POST" enctype="multipart/form-data"> <!-- to use multer Don’t forget the enctype="multipart/form-data" in your form. -->

        
            <div class="form-group">
              <label for="yearEquipment">Equipment Year</label>
              <input type="text" class="form-control" id="year" aria-describedby="emailHelp" placeholder="Enter Year Of Equipment" name="year" required>
              
            </div>
            <div class="form-group">
              <label for="nameEquipment">Name</label>
              <input type="text" class="form-control" id="description" placeholder="Enter Name/ Description of the equipment" name="description" required>
            </div>
            <div class="form-group">
              <label for="nameEquipment">Model</label>
              <input type="text" class="form-control" id="description" placeholder="Enter Model of the equipment" name="model" required>
            </div>
            <div class="form-group">
              <label for="purchaseDate">Date of Purchase</label>
              <input type="date" class="form-control" id="purchase" placeholder="Enter Date of Purchase" name="purchase">
            </div>
            <div class="form-group form-check">
                <input type="checkbox" class="form-check-input" id="isDriveable" name="isDriveable">
                <label class="form-check-label" for="isDriveable">Check Box if equipment is driveable</label>
            </div>
            <div class="form-group">
              <label for="currentLocation">Location</label>
              <input type="text" class="form-control" id="location" placeholder="Enter current location of the equipment" name="location">
            </div>
            <div class="form-group">
              <label for="currentLocation">Current user</label>
              <input type="text" class="form-control" id="currentUser" placeholder="Enter current user name" name="currentUser" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="imageEquipment">Upload Image of the Equipment</label>
              <input type="file" class="form-control" id="img" name="img" accept="image/*" required/>
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
          </form>
     </div>  
     
     <img src="/uploads/img-1678493592370.jpeg" alt="imagetest">
              
